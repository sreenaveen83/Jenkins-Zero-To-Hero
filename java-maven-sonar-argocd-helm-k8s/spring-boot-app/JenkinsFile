Is this good way of creating a Jenkinsfile?
pipeline {
  agent {
    docker {
      image 'naveenalapati9/maven-docker-agent:v6'
      args '-v /var/run/docker.sock:/var/run/docker.sock -u root:root'
    }
  }

  options {
    skipDefaultCheckout(true)
  }

  environment {
    SONAR_URL = "http://54.163.48.231:9000"
    GIT_REPO_NAME = "Jenkins-Zero-To-Hero"
    GIT_USER_NAME = "sreenaveen83"
    DOCKER_IMAGE = "naveenalapati9/ultimate-cicd:${BUILD_NUMBER}"
    GIT_SSH_URL = "git@github.com:${GIT_USER_NAME}/${GIT_REPO_NAME}.git"
  }

  stages {
    stage('Checkout SCM') {
      steps {
        sh 'rm -rf ./* ./.git || true'
        checkout scm

        script {
          sh "git config --global --add safe.directory '*'"

          def commitAuthor = sh(
            script: "git log -1 --pretty=format:'%an'",
            returnStdout: true
          ).trim()

          if (commitAuthor == "Jenkins CI Bot") {
            currentBuild.result = 'ABORTED'
            error("Stopping build: Commit was made by ${commitAuthor} (Loop Prevention)")
          }
        }
      }
    }

    stage('Verify Tools') {
      steps {
        sh '''
          echo "Running inside Docker agent"
          whoami
          pwd
          java -version
          mvn -version
          git --version
          docker --version
          ssh -V || true
          which ssh-keyscan || true
          ls -ltr
        '''
      }
    }

    stage('Build and Test') {
      steps {
        sh '''
          cd java-maven-sonar-argocd-helm-k8s/spring-boot-app

          echo "===== CURRENT GIT COMMIT ====="
          git rev-parse HEAD || true

          echo "===== INDEX.HTML FROM WORKSPACE ====="
          cat src/main/resources/templates/index.html

          mvn clean package
        '''
      }
    }

    stage('Static Code Analysis') {
      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
          sh '''
            cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
            mvn org.sonarsource.scanner.maven:sonar-maven-plugin:4.0.0.4121:sonar \\
              -Dsonar.token=$SONAR_AUTH_TOKEN \\
              -Dsonar.host.url=$SONAR_URL
          '''
        }
      }
    }

    stage('Build and Push Docker Image') {
      steps {
        script {
          sh '''
            cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
            docker build -t ${DOCKER_IMAGE} .
          '''

          def dockerImage = docker.image("${DOCKER_IMAGE}")
          docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
            dockerImage.push()
          }
        }
      }
    }

    stage('Update Deployment File') {
      steps {
        sshagent(credentials: ['github-ssh']) {
          sh '''
            git config --global --add safe.directory '*'
            git config --global user.email "jenkins-bot@cicd.com"
            git config --global user.name "Jenkins CI Bot"

            mkdir -p ~/.ssh
            ssh-keyscan github.com >> ~/.ssh/known_hosts
            chmod 600 ~/.ssh/known_hosts

            cd java-maven-sonar-argocd-helm-k8s

            git remote set-url origin ${GIT_SSH_URL}

            sed -i "s|image: naveenalapati9/ultimate-cicd:.*|image: naveenalapati9/ultimate-cicd:${BUILD_NUMBER}|g" \\
              spring-boot-app-manifests/deployment.yaml

            git add spring-boot-app-manifests/deployment.yaml
            git commit -m "Update deployment image to version ${BUILD_NUMBER}" || echo "No changes to commit"
            git push origin HEAD:main
          '''
        }
      }
    }
  }

  post {
    always {
      echo 'Pipeline execution completed.'
    }
    success {
      echo 'Pipeline completed successfully.'
    }
    failure {
      echo 'Pipeline failed.'
    }
  }
}

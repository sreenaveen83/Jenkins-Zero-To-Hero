pipeline {
  agent {
    docker {
      image 'naveenalapati9/maven-docker-agent:v6'
      args '-v /var/run/docker.sock:/var/run/docker.sock -u 111:113'
      reuseNode true
    }
  }

  options {
    skipDefaultCheckout(true)
    timestamps()
    disableConcurrentBuilds()
  }

  environment {
    GIT_REPO_NAME = 'Jenkins-Zero-To-Hero'
    GIT_USER_NAME = 'sreenaveen83'
    GIT_SSH_URL   = "git@github.com:${GIT_USER_NAME}/${GIT_REPO_NAME}.git"
    APP_DIR       = 'java-maven-sonar-argocd-helm-k8s/spring-boot-app'
    MANIFEST_DIR  = 'java-maven-sonar-argocd-helm-k8s'
    IMAGE_NAME    = "naveenalapati9/ultimate-cicd:${BUILD_NUMBER}"
  }

  stages {
    stage('Checkout') {
      steps {
        deleteDir()
        checkout scm

        script {
          def commitAuthor = sh(
            script: "git log -1 --pretty=format:'%an'",
            returnStdout: true
          ).trim()

          if (commitAuthor == 'Jenkins CI Bot') {
            currentBuild.result = 'ABORTED'
            error("Stopping build: commit created by ${commitAuthor}")
          }
        }
      }
    }

    stage('Verify Environment') {
      steps {
        sh '''
          whoami
          pwd
          java -version
          mvn -version
          git --version
          docker --version
        '''
      }
    }

    stage('Build') {
      steps {
        dir("${APP_DIR}") {
          sh 'mvn -B clean package'
        }
      }
    }

    stage('Test Reports') {
      steps {
        dir("${APP_DIR}") {
          junit allowEmptyResults: true, testResults: 'target/surefire-reports/*.xml'
        }
      }
    }

    stage('SonarQube Analysis') {
      environment {
        SONAR_URL = 'http://54.163.48.231:9000'
      }
      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
          dir("${APP_DIR}") {
            sh '''
              mvn -B org.sonarsource.scanner.maven:sonar-maven-plugin:4.0.0.4121:sonar \
                -Dsonar.token=$SONAR_AUTH_TOKEN \
                -Dsonar.host.url=$SONAR_URL
            '''
          }
        }
      }
    }

    stage('Build Docker Image') {
      steps {
        dir("${APP_DIR}") {
          script {
            dockerImage = docker.build("${IMAGE_NAME}")
          }
        }
      }
    }

    stage('Push Docker Image') {
      steps {
        script {
          docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
            dockerImage.push()
            dockerImage.push('latest')
          }
        }
      }
    }

    stage('Update Manifest') {
      steps {
        sshagent(credentials: ['github-ssh']) {
          dir("${MANIFEST_DIR}") {
            sh '''
              git config user.email "jenkins-bot@cicd.com"
              git config user.name "Jenkins CI Bot"

              mkdir -p ~/.ssh
              ssh-keyscan github.com >> ~/.ssh/known_hosts
              chmod 600 ~/.ssh/known_hosts

              git remote set-url origin ${GIT_SSH_URL}

              sed -i "s|image: naveenalapati9/ultimate-cicd:.*|image: ${IMAGE_NAME}|g" \
                spring-boot-app-manifests/deployment.yaml

              git add spring-boot-app-manifests/deployment.yaml

              if ! git diff --cached --quiet; then
                git commit -m "Update deployment image to version ${BUILD_NUMBER}"
                git push origin HEAD:main
              else
                echo "No manifest changes detected"
              fi
            '''
          }
        }
      }
    }
  }

  post {
    always {
      echo 'Pipeline execution completed.'
      cleanWs()
    }
    success {
      echo 'Pipeline completed successfully.'
    }
    failure {
      echo 'Pipeline failed.'
    }
    aborted {
      echo 'Pipeline aborted.'
    }
  }
}
